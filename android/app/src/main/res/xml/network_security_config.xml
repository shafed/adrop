<?xml version="1.0" encoding="utf-8"?>
<!--
    Network security config for adrop.

    We use a custom X509TrustManager that pins peer certificates, so we must
    permit cleartext and allow user certs to be overridden only for our own
    TLS code. Everything runs over TLS 1.3 in practice.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- We do NOT trust any system CA. Our PinningTrustManager handles
                 all trust decisions programmatically via fingerprint pinning. -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
